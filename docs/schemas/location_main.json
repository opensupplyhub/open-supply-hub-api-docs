{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "This schema represents a location without claimant data.",
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 200,
      "description": "The name of the location (preferably in English)."
    },
    "wage_indicator": {
      "type": "array",
      "description": "WageIndicator links related to minimum and living wage information for the location’s country.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": ["string", "null"]
          },
          "value": {
            "type": "object",
            "properties": {
              "raw_values": {
                "type": "object",
                "properties": {
                  "living_wage_link_national": {
                    "type": "string"
                  },
                  "living_wage_link_national_text": {
                    "type": "string"
                  },
                  "minimum_wage_link_english": {
                    "type": "string"
                  },
                  "minimum_wage_link_english_text": {
                    "type": "string"
                  },
                  "minimum_wage_link_national": {
                    "type": "string"
                  },
                  "minimum_wage_link_national_text": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "required": ["raw_values"],
            "additionalProperties": false
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "field_name": {
            "type": "string",
            "const": "wage_indicator"
          },
          "contributor": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "name": { "type": "string" },
              "admin_id": { "type": "number" },
              "is_verified": { "type": "boolean" },
              "contrib_type": { "type": "string" }
            },
            "required": ["id", "name", "admin_id", "is_verified", "contrib_type"],
            "additionalProperties": false
          },
          "is_verified": {
            "type": "boolean"
          },
          "value_count": {
            "type": "integer",
            "minimum": 0
          },
          "facility_list_item_id": {
            "type": "integer"
          },
          "should_display_association": {
            "type": "boolean"
          }
        },
        "required": ["value", "created_at", "updated_at", "field_name", "contributor", "is_verified", "value_count", "facility_list_item_id", "should_display_association"],
        "additionalProperties": false
      }
    },
    "mit_living_wage": {
      "type": "array",
      "description": "MIT Living Wage data associated with the location.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": ["string", "null"]
          },
          "value": {
            "type": "object",
            "properties": {
              "raw_values": {
                "type": "object",
                "properties": {
                  "county_id": {
                    "type": "string"
                  }
                },
                "required": ["county_id"],
                "additionalProperties": false
              }
            },
            "required": ["raw_values"],
            "additionalProperties": false
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "field_name": {
            "type": "string",
            "const": "mit_living_wage"
          },
          "contributor": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "name": { "type": "string" },
              "admin_id": { "type": "number" },
              "is_verified": { "type": "boolean" },
              "contrib_type": { "type": "string" }
            },
            "required": ["id", "name", "admin_id", "is_verified", "contrib_type"],
            "additionalProperties": false
          },
          "is_verified": {
            "type": "boolean"
          },
          "value_count": {
            "type": "integer",
            "minimum": 0
          },
          "facility_list_item_id": {
            "type": "integer"
          },
          "should_display_association": {
            "type": "boolean"
          }
        },
        "required": ["value", "created_at", "updated_at", "field_name", "contributor", "is_verified", "value_count", "facility_list_item_id", "should_display_association"],
        "additionalProperties": false
      }
    },
    "address": {
      "type": "string",
      "maxLength": 200,
      "description": "The address of the location."
    },
    "country": {
      "type": "string",
      "description": "The country of the location (can be a country code or name see https://www.iban.com/country-codes)."
    },
    "sector": {
      "type": "array",
      "minItems": 1,
      "description": "The sector that the location operates in.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "parent_company": {
      "type": "string",
      "description": "The name of the parent company of the location."
    },
    "product_type": {
      "type": "array",
      "description": "The product types that the location produces.",
      "items": {
        "type": "string"
      }
    },
    "location_type": {
      "type": "array",
      "minItems": 1,
      "description": "The type of location this location represents.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "processing_type": {
      "type": "array",
      "minItems": 1,
      "description": "The type of processing activity that takes place at this location.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "number_of_workers": {
      "type": "object",
      "description": "The number of workers that are employed at a location.",
      "properties": {
        "min": {
          "type": "number",
          "description": "The minimum number. Must be less than or equal to 'max'.",
          "minimum": 1
        },
        "max": {
          "type": "number",
          "description": "The maximum number. Must be greater than or equal to 'min'.",
          "minimum": 1
        }
      },
      "required": ["min", "max"],
      "additionalProperties": false
    },
    "coordinates": {
      "type": "object",
      "description": "The coordinates of the location.",
      "properties": {
        "lat": {
          "type": "number",
          "description": "The latitude of the location.",
          "minimum": -90,
          "maximum": 90
        },
        "lng": {
          "type": "number",
          "description": "The longitude of the location.",
          "minimum": -180,
          "maximum": 180
        }
      },
      "required": ["lat", "lng"],
      "additionalProperties": false
    }
  }
}
