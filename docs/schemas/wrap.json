{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "title": "WRAP Certification",
    "description": "WRAP certification status and dates for the location.",
    "properties": {
        "certification_status": {
            "type": "string",
            "title": "Status",
            "description": "The current certification status.",
            "enum": ["active", "inactive"]
        },
        "start_date": {
            "type": "string",
            "format": "date",
            "title": "Issue Date",
            "description": "The date the certification was issued."
        },
        "expiration_date": {
            "type": "string",
            "format": "date",
            "title": "Expiration Date",
            "description": "The date the certification expires."
        }
    },
    "additionalProperties": false
}
