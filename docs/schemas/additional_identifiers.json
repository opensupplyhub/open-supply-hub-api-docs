{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "description": "This schema represents additional identifiers object.",
    "properties": {
        "duns_id": {
            "type": "string",
            "maxLength": 9,
            "minLength": 9,
            "pattern": "^[0-9]{9}$",
            "example": "123456789",
            "description": "The DUNS ID of the location."
        },
        "lei_id": {
            "type": "string",
            "maxLength": 20,
            "minLength": 20,
            "pattern": "^([A-Z0-9]{18}[0-9]{2})$",
            "example": "2UZHAXXGYP0WQQCV9X72",
            "description": "The LEI ID of the location."
        },
        "rba_id": {
            "type": "string",
            "maxLength": 255,
            "description": "The RBA ID of the location."
        },
        "isic_4": {
          "type": "array",
          "minItems": 1,
          "maxItems": 15,
          "description": "ISIC Rev.4 classifications related to the production location. Each item may include any of: class, group, section, division.",
          "items": {
            "type": "object",
            "properties": {
              "class": {
                "type": "string",
                "minLength": 1,
                "description": "ISIC class value."
              },
              "group": {
                "type": "string",
                "minLength": 1,
                "description": "ISIC group value."
              },
              "section": {
                "type": "string",
                "minLength": 1,
                "description": "ISIC section value."
              },
              "division": {
                "type": "string",
                "minLength": 1,
                "description": "ISIC division value."
              }
            }
          }
        }
    }
}
